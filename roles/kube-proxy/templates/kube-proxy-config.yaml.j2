apiVersion: kubeproxy.config.k8s.io/v1alpha1
bindAddress: "0.0.0.0"
clientConnection:
  acceptContentTypes: ""
  burst: 10
  contentType: application/vnd.kubernetes.protobuf
  kubeconfig: /etc/kubernetes/kube-proxy.kubeconfig
  qps: 5
clusterCIDR: "{{ CLUSTER_CIDR }}"
configSyncPeriod: "15m"
conntrack:
  maxPerCore: 32768
  min: 131072
  tcpCloseWaitTimeout: "1h0m0s"
  tcpEstablishedTimeout: "24h0m0s"
enableProfiling: false
healthzBindAddress: "0.0.0.0:{{ kube_proxy_healthz_port }}"
iptables:
  masqueradeAll: false
  masqueradeBit: 14
  minSyncPeriod: "0s"
  syncPeriod: "30s"
ipvs:
  minSyncPeriod: "0s"
  scheduler: "{{ kube_proxy_ipvs_scheduler }}"
  syncPeriod: "30s"
kind: KubeProxyConfiguration
metricsBindAddress: "0.0.0.0:{{ kube_proxy_metrics_port }}"
mode: "{{ kube_proxy_proxy_mode }}"
oomScoreAdj: -999
