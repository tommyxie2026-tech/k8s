user nginx;
worker_processes auto;
error_log /var/log/nginx/error.log error;
pid /run/nginx.pid;

events {
    worker_connections {{ nginx_worker_connections }};
}

stream {
    log_format basic '$remote_addr [$time_local] '
                      '$protocol $status $bytes_sent $bytes_received '
                      '$session_time';
    access_log /var/log/nginx/apiserver-access.log basic;

    upstream kube-apiserver {
{% for host in groups['kube_master'] %}
        server {{ hostvars[host]['ansible_host'] }}:6443 max_fails={{ nginx_upstream_max_fails }} fail_timeout={{ nginx_upstream_fail_timeout }};
{% endfor %}
    }

    server {
        listen 0.0.0.0:{{ LB_APISERVER_PORT }};
        proxy_connect_timeout {{ nginx_proxy_connect_timeout }};
        proxy_timeout {{ nginx_proxy_timeout }};
        proxy_pass kube-apiserver;
    }
}
