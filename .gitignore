# Ansible runtime
*.retry

# Binary cache
# files/<arch>/ is intentionally versioned through Git LFS for default offline artifacts.
# Do not ignore files/ here.

# Generated certificates and kubeconfigs
/ssl_build/
/.ssl_build/
/.k8s/
**/ssl_build/
**/.ssl_build/
*.pem
*.key
*.csr
*.kubeconfig

# Local inventories and environment overrides
inventories/prod/*.yml
!inventories/prod/*.example.yml
*.local.yml
.env
.env.*

# Logs and temp files
*.log
/tmp/

# Keep binary archives trackable under files/<arch>/ via Git LFS.
# Archive files outside files/ remain ignored.
*.tar.gz
*.tgz
!files/**/*.tar.gz
!files/**/*.tgz

# macOS / editor
.DS_Store
.idea/
.vscode/
